---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Edgardo Vásquez Valenzuela | Solutions Architect · Tech Lead",
	description = "Portafolio Profesional de Edgardo Vásquez Valenzuela - Solutions Architect, Tech Lead y Senior Software Engineer. 12 años de experiencia construyendo plataformas críticas."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" data-i18n-attr="lang">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/mpedf3pv-img.jpg" />
    <title>{title}</title>

    <!-- Preconnect hints for critical third-party origins -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://cdn.simpleicons.org" />

    <!-- Google Fonts: preconnect + preload woff2 critical weights -->
    <link rel="preload" as="font" href="https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7W0Q5nw.woff2" type="font/woff2" crossorigin>
    <link rel="preload" as="font" href="https://fonts.gstatic.com/s/outfit/v15/QGYvz_MVcBeNP4NJtEtqUYLknw.woff2" type="font/woff2" crossorigin>
    <link rel="preload" as="font" href="https://fonts.gstatic.com/s/firacode/v27/uU9NCBsR6Z2vfE9aq3bh3dSDqFGedA.woff2" type="font/woff2" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600&family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700;800;900&display=swap" media="print" onload="this.media='all'; this.onload=null;" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600&family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700;800;900&display=swap" /></noscript>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HQ7V2L86TR" is:inline></script>
    <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-HQ7V2L86TR');
    </script>

    <!-- Script síncrono para evitar el parpadeo del tema claro/oscuro -->
    <script is:inline>
        const initialTheme = localStorage.getItem('theme') ||
            (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.setAttribute('data-theme', initialTheme);
        requestAnimationFrame(() => document.documentElement.classList.add('ready'));
    </script>
</head>
<body>
    <slot />
    <script>
        import i18next from 'i18next';
        import es from '../i18n/es.json';
        import en from '../i18n/en.json';

        const SUPPORTED_LANGS = ['es', 'en'];

        function getInitialLang() {
            const stored = localStorage.getItem('lang');
            if (stored && SUPPORTED_LANGS.includes(stored)) return stored;
            const browser = navigator.language?.split('-')[0];
            if (browser && SUPPORTED_LANGS.includes(browser)) return browser;
            return 'es';
        }

        i18next.init({
            lng: getInitialLang(),
            fallbackLng: 'es',
            resources: {
                es: { translation: es },
                en: { translation: en }
            }
        });

        function applyTranslations() {
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                const translation = i18next.t(key);
                if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
                    const attr = el.getAttribute('data-i18n-attr') || 'placeholder';
                    el.setAttribute(attr, translation);
                } else {
                    el.textContent = translation;
                }
            });
            document.documentElement.lang = i18next.language;
        }

        function changeLanguage(lng) {
            i18next.changeLanguage(lng);
            localStorage.setItem('lang', lng);
            applyTranslations();
            document.dispatchEvent(new CustomEvent('languageChanged', { detail: lng }));
        }

        applyTranslations();
        window.__i18n = { changeLanguage, applyTranslations, currentLang: () => i18next.language };
    </script>
</body>
</html>
