<section class="kpi" id="kpi-section">
    <div class="container">
        <div class="kpi-grid" style="grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));">
            <div class="kpi-card" style="text-align: center;">
                <div class="kpi-value gradient-text" style="font-size: 2.5rem; font-weight: 800;">12</div>
                <div class="kpi-label">Años de experiencia</div>
                <div class="kpi-desc" style="font-size: 0.8rem;">Desarrollo y arquitectura</div>
            </div>
            <div class="kpi-card" style="text-align: center;">
                <div class="kpi-value gradient-text" style="font-size: 2.5rem; font-weight: 800;">99.9%</div>
                <div class="kpi-label">Uptime sostenido</div>
                <div class="kpi-desc" style="font-size: 0.8rem;">Sistemas críticos en DataSoft</div>
            </div>
            <div class="kpi-card" style="text-align: center;">
                <div class="kpi-value gradient-text" style="font-size: 2.5rem; font-weight: 800;">10.000+</div>
                <div class="kpi-label">Transacciones / hora</div>
                <div class="kpi-desc" style="font-size: 0.8rem;">Alta concurrencia en DataSoft</div>
            </div>
            <div class="kpi-card" style="text-align: center;">
                <div class="kpi-value gradient-text" style="font-size: 2.5rem; font-weight: 800;">7</div>
                <div class="kpi-label">Proyectos en producción</div>
                <div class="kpi-desc" style="font-size: 0.8rem;">Portafolio visible</div>
            </div>
            <div class="kpi-card" style="text-align: center;">
                <div class="kpi-value gradient-text" style="font-size: 2.5rem; font-weight: 800;">20+</div>
                <div class="kpi-label">Tecnologías dominadas</div>
                <div class="kpi-desc" style="font-size: 0.8rem;">Skills matrix</div>
            </div>
        </div>
    </div>
</section>
