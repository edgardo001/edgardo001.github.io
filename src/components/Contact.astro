---

<section class="contact" id="contact-section">
    <div class="container">
        <div class="contact-grid">

            <div class="contact-info-block">
                <span class="kicker" data-i18n="contact.kicker">Canales Disponibles</span>
                <h2 class="section-title" data-i18n="contact.title">Hablemos</h2>
                <p class="contact-subtitle section-desc" data-i18n="contact.desc">
                    ¿Buscas un Tech Lead para tu equipo, necesitas asesoría técnica en un proyecto, o quieres una landing page para tu negocio? Cuéntame tu caso. Sin compromiso.
                </p>
                <p class="contact-availability" style="margin-top: 1rem; font-weight: 600; color: var(--text-color); display: flex; align-items: center; gap: 0.5rem;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" style="color: #22c55e;"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></svg>
                    <span data-i18n="contact.availability">Disponible · Respondo en menos de 24 horas</span>
                </p>

                <div class="contact-details">
                    <a href="https://wa.me/56999219760" class="contact-method" target="_blank" rel="noopener">
                        <span class="contact-method-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
                        <div class="contact-method-text">
                            <h3>Móvil / WhatsApp</h3>
                            <p>(+56) 9 992 19760</p>
                        </div>
                    </a>

                    <a href="mailto:edgardo.a.v@gmail.com" class="contact-method">
                        <span class="contact-method-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span>
                        <div class="contact-method-text">
                            <h3>Correo Electrónico</h3>
                            <p>edgardo.a.v@gmail.com</p>
                        </div>
                    </a>

                    <a href="https://github.com/edgardo001" class="contact-method" target="_blank" rel="noopener">
                        <span class="contact-method-icon"><svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg></span>
                        <div class="contact-method-text">
                            <h3>GitHub</h3>
                            <p>@edgardo001</p>
                        </div>
                    </a>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="contact-form-wrapper">
                <form id="contact-form">
                    <div class="form-group">
                        <label class="form-label" for="form-name" data-i18n="contact.form.nameLabel">Nombre Completo</label>
                        <input type="text" class="form-input" id="form-name" required data-i18n-attr="placeholder" data-i18n="contact.form.namePlaceholder" placeholder="Escriba su nombre">
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="form-subject" data-i18n="contact.form.subjectLabel">Asunto de Consulta</label>
                        <input type="text" class="form-input" id="form-subject" required data-i18n-attr="placeholder" data-i18n="contact.form.subjectPlaceholder" placeholder="Ej: Tengo una posición abierta, necesito consultoría en arquitectura, quiero una landing page para mi negocio...">
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="form-message" data-i18n="contact.form.messageLabel">Mensaje del Proyecto</label>
                        <textarea class="form-input" id="form-message" required data-i18n-attr="placeholder" data-i18n="contact.form.messagePlaceholder" placeholder="Describa brevemente los desafíos técnicos de su negocio..."></textarea>
                    </div>
                    <button type="submit" class="btn-submit" data-i18n="contact.form.submit">ENVIAR VÍA WHATSAPP</button>
                </form>
            </div>

        </div>
    </div>
</section>

<!-- Floating WhatsApp Action -->
<a href="https://wa.me/56999219760" class="wa-float" target="_blank" aria-label="Contacto por WhatsApp">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M19.077 4.928C17.191 3.041 14.683 2 12.006 2c-5.35 0-9.71 4.36-9.71 9.71 0 1.71.447 3.38 1.298 4.85L2.5 21.5l4.941-1.29a9.685 9.685 0 004.565 1.158h.004c5.35 0 9.71-4.36 9.71-9.71 0-2.593-1.008-5.036-2.843-6.87zM12.01 19.994h-.004a8.062 8.062 0 01-4.106-1.125l-.294-.175-2.934.767.784-2.86-.19-.302a8.052 8.052 0 01-1.24-4.29c0-4.46 3.63-8.09 8.094-8.09 2.161 0 4.193.843 5.72 2.37a8.074 8.074 0 012.372 5.724c-.001 4.46-3.63 8.09-8.092 8.09zm4.44-6.058c-.243-.122-1.44-.71-1.663-.792-.222-.08-.384-.122-.545.122-.162.244-.63.792-.772.955-.142.163-.284.183-.527.061-.244-.122-1.029-.38-1.96-1.21-.724-.645-1.214-1.442-1.354-1.686-.142-.243-.015-.376.107-.498.11-.11.245-.284.367-.427.122-.143.163-.244.245-.407.082-.163.04-.305-.02-.427-.06-.122-.548-1.322-.753-1.81-.199-.474-.4-.41-.548-.418-.143-.008-.305-.008-.468-.008-.163 0-.427.061-.65.305-.223.244-.853.834-.853 2.033 0 1.199.874 2.357.995 2.52.122.163 1.718 2.625 4.163 3.678.582.251 1.035.4 1.39.512.582.186 1.115.16 1.534.097.482-.07 1.44-.59 1.643-1.158.204-.569.204-1.057.143-1.158-.062-.102-.224-.163-.468-.285z" fill="white"/>
    </svg>
</a>

<script>
    const contactForm = document.getElementById('contact-form');
    contactForm?.addEventListener('submit', function(e) {
        e.preventDefault();
        const nameInput = document.getElementById('form-name') as HTMLInputElement | null;
        const subjectInput = document.getElementById('form-subject') as HTMLInputElement | null;
        const messageInput = document.getElementById('form-message') as HTMLTextAreaElement | null;

        if (nameInput && subjectInput && messageInput) {
            const name = nameInput.value;
            const subject = subjectInput.value;
            const message = messageInput.value;

            const rawMessage = `Hola Edgardo,\n\nMi nombre es ${name}.\nMe comunico para consultar sobre: *${subject}*.\n\n*Detalles del Proyecto:*\n${message}`;
            const encodedText = encodeURIComponent(rawMessage);

            const whatsappUrl = `https://wa.me/+56999219760?text=${encodedText}`;
            window.open(whatsappUrl, '_blank');
        }
    });
</script>
