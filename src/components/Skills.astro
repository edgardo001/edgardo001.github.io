---
---

<section class="skills" id="skills-matrix">
    <div class="container">
        <div class="section-header">
            <span class="kicker">Habilidades Técnicas & Estratégicas</span>
            <h2 class="section-title">Matriz de Habilidades</h2>
            <p class="section-desc">
                Perfil híbrido balanceado que integra liderazgo de equipos de alto rendimiento con arquitectura de sistemas de gran envergadura y seguridad de datos.
            </p>
        </div>

        <!-- Filter Controls -->
        <div class="filter-container">
            <button class="filter-btn active" data-filter="all">Todas</button>
            <button class="filter-btn" data-filter="liderazgo">Liderazgo & Estrategia</button>
            <button class="filter-btn" data-filter="arquitectura">Arquitectura & Seguridad</button>
            <button class="filter-btn" data-filter="devops">DevOps & Cloud</button>
            <button class="filter-btn" data-filter="codigo">Patrones & Código</button>
            <button class="filter-btn" data-filter="observabilidad">Observabilidad & IA</button>
            <button class="filter-btn" data-filter="ai-tools">Plataformas IA</button>
        </div>

        <!-- Skills Grid -->
        <div class="skills-grid" id="skills-grid">
            <div class="skill-card" data-category="liderazgo">
                <h3>Dirección de Equipos <span class="skill-icon-indicator"></span></h3>
                <div class="skill-list">
                    <span class="skill-item">Liderazgo de Equipos (hasta 5 pers.)</span>
                    <span class="skill-item">Mentoring Técnico</span>
                    <span class="skill-item">Reclutamiento y Onboarding</span>
                    <span class="skill-item">Gestión del Cambio</span>
                </div>
            </div>

            <div class="skill-card" data-category="liderazgo">
                <h3>Metodologías Ágiles <span class="skill-icon-indicator"></span></h3>
                <div class="skill-list">
                    <span class="skill-item">Scrum / Kanban</span>
                    <span class="skill-item">Lean Operations</span>
                    <span class="skill-item">Lean Change Management</span>
                    <span class="skill-item">Continuidad de Negocio</span>
                </div>
            </div>

            <div class="skill-card" data-category="arquitectura">
                <h3>Seguridad Criptográfica <span class="skill-icon-indicator"></span></h3>
                <div class="skill-list">
                    <span class="skill-item">Infraestructura de Llave Pública</span>
                    <span class="skill-item">HSM Thales Integration</span>
                    <span class="skill-item">Cifrado AES256</span>
                    <span class="skill-item">Key Management Centralizado</span>
                </div>
            </div>

            <div class="skill-card" data-category="devops">
                <h3>Microsoft Azure & Cloudflare <span class="skill-icon-indicator"></span></h3>
                <div class="skill-list">
                    <span class="skill-item">Azure PaaS / IaaS</span>
                    <span class="skill-item">Azure Blob Storage</span>
                    <span class="skill-item">Cloudflare WAF / CDN</span>
                    <span class="skill-item">Optimización de Costos Cloud</span>
                </div>
            </div>

            <div class="skill-card" data-category="devops">
                <h3>DevOps & CI/CD <span class="skill-icon-indicator"></span></h3>
                <div class="skill-list">
                    <span class="skill-item">Azure DevOps</span>
                    <span class="skill-item">Git / GitHub / GitLab</span>
                    <span class="skill-item">Pipelines Automatizados</span>
                    <span class="skill-item">Linux Admin</span>
                </div>
            </div>

            <div class="skill-card" data-category="codigo">
                <h3>Patrones & Arquitectura de Software <span class="skill-icon-indicator"></span></h3>
                <div class="skill-list">
                    <span class="skill-item">Arquitectura N-Capas</span>
                    <span class="skill-item">Modelo Vista Controlador (MVC)</span>
                    <span class="skill-item">Diseño Orientado a Objetos (OOP)</span>
                    <span class="skill-item">Programación Funcional & Aspectos</span>
                </div>
            </div>

            <div class="skill-card" data-category="codigo">
                <h3>Lenguajes & Frameworks <span class="skill-icon-indicator"></span></h3>
                <div class="skill-list">
                    <span class="skill-item">
                        <img src="https://cdn.simpleicons.org/dotnet/512BD4" width="13" height="13" alt=".NET">
                        .NET (C#)
                    </span>
                    <span class="skill-item">
                        <img src="https://cdn.simpleicons.org/springboot/6DB33F" width="13" height="13" alt="Spring Boot">
                        Java / Spring Boot
                    </span>
                    <span class="skill-item">
                        <img src="https://cdn.simpleicons.org/python/3776AB" width="13" height="13" alt="Python">
                        Python
                    </span>
                    <span class="skill-item">
                        <img src="https://cdn.simpleicons.org/nodedotjs/339933" width="13" height="13" alt="Node.js">
                        Node.js
                    </span>
                </div>
            </div>

            <div class="skill-card" data-category="codigo">
                <h3>Bases de Datos <span class="skill-icon-indicator"></span></h3>
                <div class="skill-list">
                    <span class="skill-item">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13" style="color:#CC2927"><path d="M12 2C6.477 2 2 4.686 2 8v8c0 3.314 4.477 6 10 6s10-2.686 10-6V8c0-3.314-4.477-6-10-6zm8 12c0 1.88-3.371 4-8 4s-8-2.12-8-4v-2.268C5.619 13.31 8.609 14 12 14s6.381-.69 8-1.268V14zm0-5c0 1.88-3.371 4-8 4s-8-2.12-8-4s3.371-4 8-4s8 2.12 8 4z"/></svg>
                        SQL Server
                    </span>
                    <span class="skill-item">
                        <img src="https://cdn.simpleicons.org/postgresql/4169E1" width="13" height="13" alt="PostgreSQL">
                        PostgreSQL
                    </span>
                    <span class="skill-item">
                        <img src="https://cdn.simpleicons.org/mongodb/47A248" width="13" height="13" alt="MongoDB">
                        MongoDB
                    </span>
                </div>
            </div>

            <div class="skill-card" data-category="observabilidad">
                <h3>Observabilidad & Pruebas <span class="skill-icon-indicator"></span></h3>
                <div class="skill-list">
                    <span class="skill-item">
                        <img src="https://cdn.simpleicons.org/grafana/F46800" width="13" height="13" alt="Grafana">
                        <img src="https://cdn.simpleicons.org/prometheus/E6522C" width="13" height="13" alt="Prometheus">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13" style="color:#F46800"><path d="M12 2c-.5 2-2 3.5-2 6 0 1.1.9 2 2 2s2-.9 2-2c0-2.5-1.5-4-2-6zM7 10c-1.7 0-3 1.3-3 3v7h16v-7c0-1.7-1.3-3-3-3H7zm1 2h8c.6 0 1 .4 1 1v5H7v-5c0-.6.4-1 1-1z"/></svg>
                        Grafana Stack (Prometheus/Loki)
                    </span>
                    <span class="skill-item">
                        <img src="https://cdn.simpleicons.org/apachejmeter/D22128" width="13" height="13" alt="JMeter">
                        <img src="https://cdn.simpleicons.org/k6/7D64FF" width="13" height="13" alt="k6">
                        JMeter / Grafana K6
                    </span>
                    <span class="skill-item">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13" style="color:#85C540"><path d="M8.5 3a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zM12 6C8.686 6 6 8.239 6 11c0 1.38.622 2.624 1.625 3.525C6.634 15.117 6 16.252 6 17.5 6 19.985 8.686 22 12 22s6-2.015 6-4.5c0-1.248-.634-2.383-1.625-2.975C17.378 13.624 18 12.38 18 11c0-2.761-2.686-5-6-5zm0 2c2.206 0 4 1.346 4 3s-1.794 3-4 3-4-1.346-4-3 1.794-3 4-3zm0 8c2.206 0 4 1.121 4 2.5S14.206 21 12 21s-4-1.121-4-2.5S9.794 16 12 16z"/></svg>
                        <img src="https://cdn.simpleicons.org/postman/FF6C37" width="13" height="13" alt="Postman">
                        SoapUI / Postman
                    </span>
                    <span class="skill-item">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13" style="color:#F2C811"><path d="M4 20h2V9H4v11zm5 0h2V4H9v16zm5 0h2v-7h-2v7zm5 0h2v-4h-2v4z"/></svg>
                        Power BI
                    </span>
                </div>
            </div>

            <div class="skill-card" data-category="observabilidad">
                <h3>Innovación & LLMs <span class="skill-icon-indicator"></span></h3>
                <div class="skill-list">
                    <span class="skill-item">Gemini API Integration</span>
                    <span class="skill-item">ChatGPT & DeepSeek LLMs</span>
                    <span class="skill-item">Pair Programming (GitHub Copilot)</span>
                    <span class="skill-item">Automatización Corporativa</span>
                </div>
            </div>

            <div class="skill-card" data-category="ai-tools">
                <h3>Plataformas & Herramientas IA <span class="skill-icon-indicator"></span></h3>
                <div class="skill-list">
                    <span class="skill-item">
                        <img src="https://cdn.simpleicons.org/anthropic/D97757" width="13" height="13" alt="Claude">
                        Claude
                    </span>
                    <span class="skill-item">
                        <img src="https://cdn.simpleicons.org/googlegemini/4285F4" width="13" height="13" alt="Gemini">
                        Gemini
                    </span>
                    <span class="skill-item">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13"><path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.677l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.896zm16.597 3.855-5.843-3.369 2.02-1.168a.076.076 0 0 1 .071 0l4.83 2.786a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.402-.676zm2.01-3.023-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135-2.02-1.164a.08.08 0 0 1-.038-.057v-5.57a4.492 4.492 0 0 1 7.375-3.453l-.142.08L8.704 9.47a.795.795 0 0 0-.393.681zm1.097-2.365 2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z"/></svg>
                        Codex / OpenAI
                    </span>
                    <span class="skill-item">
                        <img src="https://cdn.simpleicons.org/ollama/ffffff" width="13" height="13" alt="Ollama" class="icon-invert">
                        Ollama
                    </span>
                    <span class="skill-item">
                        <img src="https://cdn.simpleicons.org/openrouter/6467F2" width="13" height="13" alt="OpenRouter">
                        OpenRouter
                    </span>
                    <span class="skill-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--accent-emerald)"><path d="M12 2 8 9H3l4.5 4-1.5 7L12 17l6 3-1.5-7L21 9h-5L12 2z"/></svg>
                        Antigravity
                    </span>
                    <span class="skill-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--accent-emerald)"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="m7 13 3-3-3-3M13 13h4"/></svg>
                        Antigravity CLI
                    </span>
                    <span class="skill-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><circle cx="17.5" cy="17.5" r="3.5"/></svg>
                        OpenDesign
                    </span>
                    <span class="skill-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--accent-indigo)"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                        Kilocode
                    </span>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(4px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<script>
    // Interactive Habilidades Matrix Filter
    const filterButtons = document.querySelectorAll('.filter-btn');
    const skillCards = document.querySelectorAll('.skill-card');

    filterButtons.forEach(button => {
        button.addEventListener('click', () => {
            filterButtons.forEach(btn => btn.classList.remove('active'));
            button.classList.add('active');

            const filterValue = button.getAttribute('data-filter');

            skillCards.forEach(card => {
                const cardCategory = card.getAttribute('data-category');
                if (card instanceof HTMLElement) {
                    if (filterValue === 'all' || cardCategory === filterValue) {
                        card.style.display = 'block';
                        card.style.animation = 'fadeIn 0.4s ease-out forwards';
                    } else {
                        card.style.display = 'none';
                    }
                }
            });
        });
    });
</script>
