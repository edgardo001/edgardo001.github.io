---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const blogEntries = await getCollection('blog');
blogEntries.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="Blog — Edgardo Vásquez" description="Artículos sobre tecnología, liderazgo y arquitectura de software.">
	<main class="blog-listing">
		<section class="container">
			<header class="blog-listing-header">
				<a href="/" class="blog-back-home">&larr; Inicio</a>
				<h1 class="blog-listing-title">Blog</h1>
				<p class="blog-listing-desc">Artículos sobre tecnología, liderazgo, arquitectura cloud y más.</p>
			</header>

			{
				blogEntries.length > 0 ? (
					<div class="blog-grid">
						{blogEntries.map(entry => <BlogCard entry={entry} />)}
					</div>
				) : (
					<div class="blog-empty">
						<p>Aún no hay artículos publicados. ¡Vuelve pronto!</p>
					</div>
				)
			}
		</section>
	</main>
</Layout>

<style>
	.blog-listing {
		padding: 140px 0 80px;
		min-height: 60vh;
	}

	.blog-listing-header {
		margin-bottom: 48px;
	}

	.blog-back-home {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--accent-emerald);
		margin-bottom: 16px;
		transition: var(--transition);
	}
	.blog-back-home:hover {
		color: var(--accent-indigo);
	}

	.blog-listing-title {
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 5vw, 3.5rem);
		font-weight: 900;
		letter-spacing: -0.03em;
		line-height: 1.05;
		margin-bottom: 16px;
	}

	.blog-listing-desc {
		font-size: 1.15rem;
		color: var(--text-secondary);
		max-width: 640px;
	}

	.blog-grid {
		display: grid;
		gap: 24px;
	}

	.blog-empty {
		text-align: center;
		padding: 80px 0;
		color: var(--text-muted);
		font-size: 1.1rem;
	}
</style>
